{
  "projectType": "node-cli",
  "packageManagers": [
    "npm",
    "github-release"
  ],
  "smoke": {
    "commands": [
      [
        "npm",
        "run",
        "smoke"
      ]
    ]
  },
  "release": {
    "mode": "reviewed",
    "createGithubRelease": true,
    "publishNpm": false,
    "updateHomebrew": false
  }
}
